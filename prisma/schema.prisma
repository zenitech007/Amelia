generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

//////////////////////////////////////////////////
// USER ACCOUNT (Supabase Auth Linked)
//////////////////////////////////////////////////

model User {
  id               String            @id   // Supabase user.id
  email            String            @unique
  createdAt        DateTime          @default(now())

  profile          PatientProfile?
  chats            Chat[]
  dailyLogs        DailyLog[]
  reports          HealthReport[]
  pushSubscription PushSubscription?
  medications      Medication[]      
  memories         MedicalMemory[]   // AI SELF-LEARNING MEDICAL MEMORY
}

//////////////////////////////////////////////////
// PATIENT PROFILE
//////////////////////////////////////////////////

model PatientProfile {
  id         String @id @default(uuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id])

  firstName  String
  lastName   String

  age        Int?
  gender     String?
  weightKg   Float?
  heightCm   Float?

  bloodType  String?
  bodyShape  String?
  genotype   String?
  sugarLevel String?

  isPregnant Boolean @default(false)

  allergies    String?
  conditions   String?
  currentMeds  String?

  language     String? @default("English")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records PatientRecord[]
}

//////////////////////////////////////////////////
// MEDICAL CHAT SESSIONS
//////////////////////////////////////////////////

model Chat {
  id        String   @id @default(cuid())
  title     String
  isPinned  Boolean  @default(false)

  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages  Message[]
}

//////////////////////////////////////////////////
// AI MESSAGE HISTORY
//////////////////////////////////////////////////

model Message {
  id       String @id @default(cuid())

  role     String
  content  String

  imageUrl String?   // for medical image uploads

  createdAt DateTime @default(now())

  chatId   String
  chat     Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////
// AI HEALTH REPORTS
//////////////////////////////////////////////////

model HealthReport {
  id        String @id @default(uuid())

  title     String
  summary   String
  riskLevel String?

  recommendations String?

  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////
// PATIENT RECORDS
//////////////////////////////////////////////////

model PatientRecord {
  id          String @id @default(uuid())

  recordType  String
  title       String
  description String?

  doctorName  String?
  hospital    String?

  recordDate  DateTime
  createdAt   DateTime @default(now())

  patientProfileId String
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////
// DAILY HEALTH TRACKING
//////////////////////////////////////////////////

model DailyLog {
  id         String  @id @default(uuid())
  userId     String
  dateString String

  waterLiters Float  @default(0)
  steps       Int    @default(0)
  medsTaken   Boolean @default(false)

  notes       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateString])
}

//////////////////////////////////////////////////
// PUSH NOTIFICATIONS
//////////////////////////////////////////////////

model PushSubscription {
  id           String @id @default(uuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscription Json
}

//////////////////////////////////////////////////
// MEDICATION SCHEDULE
//////////////////////////////////////////////////

model Medication {
  id           String   @id @default(uuid())
  name         String
  dosage       String
  frequency    String
  instructions String?
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////
// AI SELF-LEARNING MEDICAL MEMORY
//////////////////////////////////////////////////

enum MemoryType {
  SYMPTOM
  MEDICATION
  ALLERGY
  VITALS
  DIAGNOSIS
  LIFESTYLE
  NOTE
}

model MedicalMemory {
  id          String   @id @default(cuid())
  userId      String
  observation String
  type        String
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
}